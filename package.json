{
  "name": "university-student-hub",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "npm run dev --prefix frontend",
    "dev:backend": "npm run dev --prefix backend",
    "dev:full": "concurrently -n backend,frontend \"npm run dev --prefix backend\" \"npm run dev --prefix frontend\"",
    "build": "npm install --prefix backend && npm install --prefix frontend --include=dev && npm run build --prefix frontend",
    "start": "npm run start --prefix backend",
    "heroku-postbuild": "npm run build",
    "check": "biome check .",
    "check:fix": "biome check . --write"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yonas-baysasaw/University-Student-Hub.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/yonas-baysasaw/University-Student-Hub/issues"
  },
  "homepage": "https://github.com/yonas-baysasaw/University-Student-Hub#readme",
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/vite": "^4.2.2",
    "concurrently": "^9.2.1",
    "daisyui": "^5.5.19",
    "tailwindcss": "^4.2.2"
  }
}
